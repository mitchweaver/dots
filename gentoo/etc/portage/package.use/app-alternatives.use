app-alternatives/gzip pigz -reference
app-alternatives/bzip2 pbzip2 -reference
app-alternatives/sh dash -reference
app-alternatives/lzip plzip -reference

# libarchive cpio/tar causes genkernel to fail initramfs
app-alternatives/tar gnu -libarchive
app-alternatives/cpio gnu -libarchive

# note: samurai doesn't support fortran so some packages will fail
###########app-alternatives/ninja reference -samurai
app-alternatives/ninja -reference samurai

