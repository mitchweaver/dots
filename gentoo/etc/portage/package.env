# =========================================================
# cannot be used/bugged with mold linker
# =========================================================
sys-devel/gcc                 no-mold.conf no-fortify-source.conf
llvm-core/llvm                no-mold.conf no-fortify-source.conf
llvm-core/clang               no-mold.conf no-fortify-source.conf
sys-libs/glibc                no-mold.conf vanilla-flags.conf
sys-devel/mold                no-mold.conf
app-emulation/libvirt         no-mold.conf
sys-apps/fwupd-efi            no-mold.conf
sys-apps/sandbox              no-mold.conf
sys-block/parted              no-mold.conf
dev-libs/leancrypto           no-mold.conf
sys-libs/libnvidia-container  no-mold.conf

# =========================================================
# 3rd party apps can't use with mold
# =========================================================
gui-apps/swappy               no-mold.conf

# =========================================================
# disable lto
# =========================================================

# =========================================================
# be careful with these
# =========================================================
sys-apps/portage                        vanilla-flags.conf
sys-libs/efivar                         vanilla-flags.conf single-thread.conf no-mold.conf

# =========================================================
# too big for tmpfs (8GB)
# =========================================================
www-client/firefox            firefox-workaround.conf notmpfs.conf
www-client/librewolf          firefox-workaround.conf notmpfs.conf
www-client/chromium           notmpfs.conf
app-office/libreoffice        notmpfs.conf
dev-lang/rust                 notmpfs.conf
dev-lang/rust-bin             notmpfs.conf
dev-lang/python               notmpfs.conf

# =========================================================
# TEMP BROKEN FIX LATER
# =========================================================
dev-qt/qtbase                         no-lto.conf vanilla-flags.conf
dev-qt/qttools                        no-lto.conf vanilla-flags.conf
llvm-runtimes/compiler-rt             no-lto.conf vanilla-flags.conf
llvm-runtimes/compiler-rt-sanitizers  no-lto.conf vanilla-flags.conf
media-libs/opencv                     vanilla-flags.conf

