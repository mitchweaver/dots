# =================================================
# Volume / Brightness
# =================================================
bindsym XF86MonBrightnessUp exec bright -i
bindsym XF86MonBrightnessDown exec bright -d
bindsym XF86AudioRaiseVolume exec vol -i
bindsym XF86AudioLowerVolume exec vol -d
bindsym mod1+semicolon exec vol -d
bindsym mod1+apostrophe exec vol -i

# mpv controls with mmt
bindsym mod1+slash exec mmt -t
bindsym mod1+bracketright exec mmt -f
bindsym mod1+bracketleft exec mmt -b
bindsym mod1+period exec mmt -n
bindsym mod1+comma exec mmt -p

