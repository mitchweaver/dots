# =================================================
# STARTUP APPS
# =================================================
exec background -s
exec dbus-update-activation-environment --all

exec dbus-launch dunst
exec dbus-launch thunar --daemon
exec wl-paste --watch cliphist store

exec bright -s 50
exec vol -u
exec vol -s 50

exec sh ~/.config/sway/gammastep.sh
exec xbanish -s

exec dbus-launch waybar >~/.cache/waybar.log 2>&1

exec swayidle -w \
         timeout 900 'lock' \
         timeout 1200 'swaymsg "output * power off"' \
         resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -e -f -c 000000'

