# =================================================
# MISC
# =================================================
popup_during_fullscreen smart
mouse_warping none
titlebar_border_thickness 0
#############titlebar_separator disable
xwayland enable
focus_follows_mouse no

# =================================================
# INPUT / OUTPUT
# =================================================
input type:keyboard {
    xkb_layout "us"
    xkb_options "caps:escape"

    # ========================================================================
    # bugging out on openbsd:
    #
    # note: default=300/30
    # repeat_delay 230
    # repeat_rate 20
    # ======================================================================== 

    # xkb_options "super_r:alt"
}

input type:touchpad {
    natural_scroll enabled
    accel_profile "flat"

    tap enabled
    tap_button_map lrm

    # disable while typing
    dwt enabled

    click_method clickfinger
    click_method button_areas
}

input type:pointer {
    accel_profile "flat"
    click_method clickfinger
}

# =================================================
# VARS
# =================================================
# note: mod1 = alt, mod4 = super
set $mod Mod1
set $super Mod4

set $left h
set $down j
set $up k
set $right l

set $term kitty

# =================================================
# GAPS / BORDERS
# =================================================
default_border pixel 0
# gaps inner 0
# gaps outer 0
gaps inner 18
gaps outer 8
# hide_edge_borders smart
smart_borders no_gaps

smart_gaps on
# smart_gaps inverse_outer

bindsym $mod+g gaps inner current plus 4
bindsym $mod+shift+g gaps inner current minus 4

