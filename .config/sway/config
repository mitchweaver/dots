# ========================================================================
# workspace configuration
# ========================================================================
workspace_auto_back_and_forth no

# ========================================================================
# Key binds
# ========================================================================
bindsym $mod+Return exec $term
bindsym $mod+w exec firefox
bindsym $mod+e exec thunar
bindsym $mod+r exec kitty ranger
bindsym $mod+p exec menu --wide run -p 'Run:' | xargs swaymsg exec --
bindsym $mod+o exec dedit
####bindsym $mod+p exec wofi -f -I -m -b -i -G --show run | xargs swaymsg exec --

# toggle between alt / super to kill so i dont accidentally kill when gaming
bindsym $mod+q kill
##########bindsym $super+q kill

bindsym $mod+shift+s exec scrap -a
bindsym $super+shift+s exec scrap -a

bindsym $mod+c   exec cliphist list | menu | cliphist decode | wl-copy
bindsym $super+v exec cliphist list | menu | cliphist decode | wl-copy

bindsym $super+l exec lock

# "kill window unless XXX"
##########bindsym $mod+q [class="steam_app_813780"] || kill

# =================================================
# Exiting / Reloading
# =================================================
bindsym $mod+Shift+c reload
bindsym $mod+Control+Shift+q exec swaynag -t warning -m 'Exit sway? ' -B 'Yes, exit sway' 'swaymsg exit'

# =================================================
# Window Focus
# =================================================
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# =================================================
# Window Moving
# =================================================
bindsym Control+Shift+$left move left
bindsym Control+Shift+$down move down
bindsym Control+Shift+$up move up
bindsym Control+Shift+$right move right

# =================================================
# Window Resizing
# =================================================
bindsym $mod+Shift+$left resize grow width 8
bindsym $mod+Shift+$right resize shrink width 8
bindsym $mod+Shift+$down resize grow height 8
bindsym $mod+Shift+$up resize shrink height 8

# =================================================
# Layouts
# =================================================
bindsym $mod+t layout toggle split
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+f floating toggle
floating_modifier $mod normal

########## bindsym $mod+s layout stacking
########## bindsym $mod+a layout tabbed

