alias dmesg='doas /bin/dmesg'

pkg() {
    [ "$1" ] || set -- h
    flag=${1#-}
    shift
    case $flag in
        s|search)
            apk search "$@"
            ;;
        a|add)
            doas apk update
            doas apk add "$@"
            ;;
        u|upgrade)
            doas apk update
            doas apk upgrade "$@"
            ;;
        d|del)
            doas apk del "$@"
            ;;
        i|info)
            apk info "$@"
            ;;
    esac
}
