# see /etc/doas.conf
#
# these commands are permitted for wheel to use without pass

# OpenBSD
if command -v pkg_add >/dev/null ; then
    alias dmesg='doas /sbin/dmesg'
    alias reboot='doas /sbin/reboot'
    alias poweroff='doas /sbin/halt -p'
# Linux / FreeBSD
elif [ -d /proc ] ; then
    alias dmesg='doas /usr/bin/dmesg'
    alias reboot='doas /usr/bin/reboot'
    alias poweroff='doas /usr/bin/poweroff'
fi
